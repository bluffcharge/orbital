   "html": "<div style=\"display:flex;flex-direction:column;gap:24px\">\n  <div style=\"display:flex;gap:12px;flex-wrap:wrap;align-items:center\">\n    <button class=\"btn btn-primary\">I deploy budget \u2192</button>\n    <button class=\"btn btn-navy\">See if you qualify</button>\n    <span class=\"pill-w\">For Buyers <span aria-hidden=\"true\">\u2192</span></span>\n  </div>\n  <div class=\"panel-c\" style=\"display:flex;gap:12px;flex-wrap:wrap;align-items:center\">\n    <span class=\"pill-w\">For Creators <span aria-hidden=\"true\">\u2192</span></span>\n    <button class=\"vg-pill\">Request access \u2197</button>\n    <button class=\"echo-cta\">Accept invitation \u2197</button>\n    <button class=\"ae-cta\">Open the exchange \u2192</button>\n    <button class=\"ae-init\">Initiate</button>\n  </div>\n  <div style=\"background:#020617;border:1px solid #CBD5E1;padding:20px;display:flex;gap:12px;flex-wrap:wrap;align-items:center\">\n    <button class=\"btn btn-ghost\">Watch the exchange \u2192</button>\n    <button class=\"nx-btn nx-pass\">Pass</button>\n    <button class=\"nx-btn nx-ok\">Approve \u2192</button>\n  </div>\n  <div class=\"shell\"><div class=\"inner\" style=\"display:flex;gap:12px;flex-wrap:wrap;align-items:center\">\n    <button class=\"btn btn-ghost\">Build a test campaign</button>\n    <button class=\"chip\">Beauty</button>\n    <button class=\"chip\">Fitness</button>\n  </div></div>\n</div>",
